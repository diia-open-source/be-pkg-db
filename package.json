{
    "name": "@diia-inhouse/db",
    "version": "10.8.8",
    "description": "Package with database connection",
    "main": "dist/index.js",
    "types": "dist/types/index.d.ts",
    "repository": "https://github.com/diia-open-source/be-pkg-db",
    "author": "Diia",
    "license": "SEE LICENSE IN LICENSE.md",
    "files": [
        "dist"
    ],
    "engines": {
        "node": ">=22"
    },
    "bin": {
        "diia-db": "dist/cli/index.js"
    },
    "exports": {
        ".": {
            "types": "./dist/types/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.js"
        },
        "./postgres": {
            "types": "./dist/types/postgres.d.ts",
            "import": "./dist/postgres.js",
            "require": "./dist/postgres.js"
        }
    },
    "scripts": {
        "prebuild": "rimraf dist",
        "build": "tsc",
        "semantic-release": "semantic-release",
        "lint": "eslint . && prettier --check .",
        "lint-fix": "eslint . --fix && prettier --write .",
        "test": "vitest run",
        "test:watch": "vitest watch",
        "prepare": "npm run build",
        "find-circulars": "madge --circular --extensions ts ./",
        "lint:lockfile": "lockfile-lint --path package-lock.json --allowed-hosts registry.npmjs.org --validate-https"
    },
    "dependencies": {
        "@diia-inhouse/crypto": "1.20.9",
        "@diia-inhouse/diia-logger": "3.19.14",
        "@diia-inhouse/diia-metrics": "6.5.23",
        "@diia-inhouse/utils": "5.3.17",
        "@diia-inhouse/validators": "1.28.27",
        "@types/migrate-mongo": "10.0.6",
        "bson": "6.10.4",
        "drizzle-orm": "0.45.2",
        "lodash": "4.18.1",
        "luxon": "3.7.2",
        "migrate-mongo": "12.1.3",
        "mongoose": "8.23.0",
        "pg": "8.19.0",
        "recursive-readdir": "2.2.3",
        "ts-node": "10.9.2",
        "yargs": "17.7.2"
    },
    "peerDependencies": {
        "@diia-inhouse/env": ">=2.0.0",
        "@diia-inhouse/errors": ">=1.6.1",
        "@diia-inhouse/types": ">=6.30.0"
    },
    "devDependencies": {
        "@diia-inhouse/configs": "6.1.1",
        "@diia-inhouse/env": "2.8.15",
        "@diia-inhouse/errors": "1.18.17",
        "@diia-inhouse/eslint-config": "8.8.0",
        "@diia-inhouse/eslint-plugin": "1.9.5",
        "@diia-inhouse/test": "7.3.16",
        "@diia-inhouse/types": "11.7.0",
        "@types/lodash": "4.17.24",
        "@types/node": "25.3.3",
        "@types/pg": "8.18.0",
        "@types/recursive-readdir": "2.2.4",
        "@types/yargs": "17.0.35",
        "@vitest/coverage-v8": "4.0.18",
        "@vitest/ui": "4.0.18",
        "dotenv-flow": "4.1.0",
        "drizzle-kit": "0.31.9",
        "eslint": "9.39.3",
        "lockfile-lint": "4.14.1",
        "madge": "8.0.0",
        "rimraf": "6.1.3",
        "semantic-release": "24.2.9",
        "typescript": "5.9.3",
        "vite-tsconfig-paths": "6.1.1",
        "vitest": "4.0.18",
        "vitest-mock-extended": "3.1.0"
    },
    "release": {
        "extends": "@diia-inhouse/configs/dist/semantic-release/package"
    },
    "commitlint": {
        "extends": "@diia-inhouse/configs/dist/commitlint"
    },
    "prettier": "@diia-inhouse/eslint-config/prettier",
    "madge": {
        "tsConfig": "./tsconfig.json"
    }
}
